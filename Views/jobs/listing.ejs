<!-- <%- layout("/layouts/boilerplate.ejs") %> -->
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/jobs/listing.css">

    <!-- Custom CSS -->
    
</head>
<body>
    <div class="mt-3 career-body">
        <!-- Filter Section -->
        <div class="filter-section">
            <h1 class="text-center filter-title">Filter Jobs</h1>
            <div class="row">
                <div class="col-md-4">
                    <select class="form-control" style="height: 3rem;">
                        <option value="">Select Job Type</option>
                        <option value="fulltime">Full-Time</option>
                        <option value="parttime">Part-Time</option>
                        <option value="internship">Internship</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-control" style="height: 3rem;">
                        <option value="">Select Location</option>
                        <option value="newyork">New York</option>
                        <option value="sanfrancisco">San Francisco</option>
                        <option value="london">London</option>
                    </select>
                </div>
                <div class="col-md-4 filter-field-input">
                    <div class="input-group">
                        <input type="text" class="form-control col-md-9" placeholder="Search by keyword...">
                        <div class="input-group-append">
                            <button class="btn btn-search rounded-end" type="button">
                                <i class="fa-solid fa-magnifying-glass"></i> Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h1 class="text-center mb-4">Job Listings</h1>
        <div class="">
            <div class="row">
                <% if (jobs && jobs.length > 0) { %>
                    <% jobs.forEach(function(job) { %>
                    <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                        <div class="job-card">
                            <div class="card-body">
                                <h5 class="card-title"><%= job.title %></h5>
                                <p class="card-text">Company: <%= job.company %></p>
                                <p class="card-text">Location: <%= job.location %></p>
                                <% if (job.jobType) { %><p class="card-text">Type: <%= job.jobType %></p><% } %>
                                <% if (job.salary) { %><p class="card-text">Salary: <%= job.salary %></p><% } %>
                                <% if (job.sector) { %><p class="card-text">Sector: <%= job.sector %></p><% } %>
                                <% if (job.description) { %><p class="card-text text-muted small"><%= job.description %></p><% } %>
                                <% if (locals.currentUser) { %>
                                    <a href="/student/job_search" class="btn btn-primary btn-block mb-3">Apply on Job Search</a>
                                <% } else { %>
                                    <a href="/login" class="btn btn-outline-primary btn-block mb-3">Login to Apply</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center">
                        <p class="text-muted">No jobs available at the moment. Check back soon!</p>
                    </div>
                <% } %>
            </div>
        </div>
        
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <!-- FontAwesome for icons -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="/javascripts/job_filters.js"></script>
</body>
</html>

