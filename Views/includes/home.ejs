<%- layout('/layouts/boilerplate.ejs') %>

<% block('head').append('<link rel="stylesheet" href="/stylesheets/home.css">') %>
<% block('head').append('<script src="https://cdn.jsdelivr.net/npm/chart.js"><\/script>') %>

<!-- Overlay -->
<div class="overlay"></div>

<!-- Popup -->
<div class="popup">
    <button class="close-btn">&times;</button>
    <img src="/images/home/loader_img.png" alt="Welcome Image">
    <div class="text-container">Welcome to Our Website!</div>
</div>

<div class="image-section">
    <img src="/images/home/job_banner.jpg" alt="Job Banner" class="responsive-image">
</div>

<!-- News Section -->
<div class="update-section">
    <div class="left-section">
        <div class="heading-container">
            <h2>Job Updates</h2>
            <a href="/jobs" class="view-all">View All</a>
        </div>
        <div class="update-card">
            <p>New job openings in tech sector. Check out the latest positions available.
                Stay ahead in your career with the latest job updates from across various sectors! Our Job Updates section brings you real-time information on the most recent and relevant job openings, tailored to meet your career aspirations.
            </p>
            <span class="timestamp">August 18, 2024 - 10:00 AM</span>
        </div>
    </div>

    <div class="right-section">
        <div class="card">
            <h3>Data Science</h3>
            <ul class="bulletin-points">
                <li><strong>Data Scientist:</strong> Analyze data to uncover trends and insights.</li>
                <li><strong>Machine Learning Engineer:</strong> Develop and deploy ML models.</li>
                <li><strong>Data Analyst:</strong> Create reports and visualizations.</li>
            </ul>
        </div>
        <div class="card">
            <h3>Full Stack Developer</h3>
            <ul class="bulletin-points">
                <li><strong>Front-End:</strong> Build UIs using HTML, CSS, JavaScript.</li>
                <li><strong>Back-End:</strong> Develop APIs using Node.js or Python.</li>
                <li><strong>Database:</strong> Design and manage databases.</li>
            </ul>
        </div>
        <div class="card">
            <h3>Construction & Infrastructure</h3>
            <p>Opportunities in civil engineering, supervision, and skilled trades across Rajasthan.</p>
        </div>
        <div class="card">
            <h3>Agriculture & Allied</h3>
            <p>Field officers, agri technicians, and rural development roles available statewide.</p>
        </div>
    </div>
</div>

<!-- Growing Sectors -->
<section class="home-static-btn">
    <h2 style="text-align: center;">Growing Sectors</h2>
    <div class="row">
        <div class="col-md-4">
            <a target="_blank" class="home-static-btn-items" href="#">
                <img src="/images/home/bg_flagship.png" alt="Technology" class="card-image">
                <h3>Technology</h3>
            </a>
        </div>
        <div class="col-md-4">
            <a href="https://sampark.rajasthan.gov.in/" target="_blank" class="home-static-btn-items">
                <img src="/images/home/helpdesk.png" alt="Education" class="card-image">
                <h3>Education</h3>
            </a>
        </div>
        <div class="col-md-4">
            <a href="#" class="home-static-btn-items">
                <img src="/images/home/bg_raj_cal.png" alt="Marketing" class="card-image">
                <h3>Marketing</h3>
            </a>
        </div>
        <div class="col-md-4">
            <a target="_blank" class="home-static-btn-items" href="https://schemes.rajasthan.gov.in?lan=en">
                <img src="/images/home/bg_sampark.png" alt="Design" class="card-image">
                <h3>Design</h3>
            </a>
        </div>
        <div class="col-md-4">
            <a target="_blank" class="home-static-btn-items" href="https://schemes.rajasthan.gov.in/scheme/flagship?lan=en">
                <img src="/images/home/bg_scheme.png" alt="Finance" class="card-image">
                <h3>Finance</h3>
            </a>
        </div>
        <div class="col-md-4">
            <a href="https://eproc.rajasthan.gov.in/nicgep/app" target="_blank" class="home-static-btn-items">
                <img src="/images/home/bg_tender.png" alt="Human Resources" class="card-image">
                <h3>Human Resources</h3>
            </a>
        </div>
    </div>
</section>

<!-- Pie Chart Section -->
<section class="pie-chart-section">
    <h2>Sector Distribution</h2>
    <div class="pie-chart-container">
        <div class="pie-chart">
            <canvas id="myPieChart"></canvas>
        </div>
        <div class="pie-chart-details">
            <h3>Chart Details</h3>
            <ul>
                <li><strong>IT:</strong> 19 units</li>
                <li><strong>Agriculture:</strong> 12 units</li>
                <li><strong>Construction:</strong> 5 units</li>
                <li><strong>Textile:</strong> 3 units</li>
                <li><strong>Healthcare:</strong> 2 units</li>
                <li><strong>Other:</strong> 3 units</li>
            </ul>
        </div>
    </div>
</section>

<!-- About Us -->
<section class="about-us">
    <div class="about-us-content">
        <h2>About Us</h2>
        <p>Welcome to the Raj Kaushal Portal, a key initiative by the Rajasthan Government aimed at fostering employment and skill development within our state. We bridge the gap between skilled workers and employers seeking talent across diverse sectors.</p>
        <p>Our platform enables workers to register, search jobs, track applications, and access counselling — all in one place. Employers can post vacancies and find the right talent efficiently.</p>
    </div>
</section>

<script src="/javascripts/home.js"></script>
