<% layout('layouts/boilerplate') %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h2 class="text-center text-primary mb-4">Create an Account</h2>
                    
                    <% if (typeof error !== 'undefined') { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>

                    <ul class="nav nav-pills nav-fill mb-4" id="signupTabs">
                        <li class="nav-item">
                            <button class="nav-link active fw-bold" id="tab-worker" type="button">I am a Worker (Job Seeker)</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link fw-bold" id="tab-employer" type="button">I am an Employer</button>
                        </li>
                    </ul>

                    <form action="/signup" method="POST" id="signupForm">
                        <input type="hidden" name="role" id="user-role" value="worker">

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" id="name-label">Full Name</label>
                                <input type="text" class="form-control" name="fullName" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" name="password" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mobile Number</label>
                                <input type="text" class="form-control" name="mobile" required>
                            </div>
                        </div>

                        <div id="worker-fields">
                            <hr class="my-4">
                            <h5 class="text-muted mb-3">Worker Details</h5>
                            
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label">Date of Birth</label>
                                    <input type="date" class="form-control" name="dob">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Gender</label>
                                    <select class="form-select" name="gender">
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Aadhar Number</label>
                                    <input type="text" class="form-control" name="aadhar">
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Highest Qualification</label>
                                    <input type="text" class="form-control" name="qualification">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Skills (Comma separated)</label>
                                    <input type="text" class="form-control" name="skills" placeholder="e.g., Welding, Driving, Python">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 mt-4">Register Account</button>
                    </form>
                    
                    <div class="text-center mt-3">
                        <small>Already have an account? <a href="/login">Login here</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const tabWorker = document.getElementById('tab-worker');
    const tabEmployer = document.getElementById('tab-employer');
    const roleInput = document.getElementById('user-role');
    const workerFields = document.getElementById('worker-fields');
    const nameLabel = document.getElementById('name-label');

    tabWorker.addEventListener('click', () => {
        // Update UI
        tabWorker.classList.add('active');
        tabEmployer.classList.remove('active');
        
        // Update Form Logic
        roleInput.value = 'worker';
        workerFields.style.display = 'block';
        nameLabel.textContent = 'Full Name';
    });

    tabEmployer.addEventListener('click', () => {
        // Update UI
        tabEmployer.classList.add('active');
        tabWorker.classList.remove('active');
        
        // Update Form Logic
        roleInput.value = 'employer';
        workerFields.style.display = 'none'; // Hide worker specific fields
        nameLabel.textContent = 'Company Name / Representative Name';
    });
});
</script>