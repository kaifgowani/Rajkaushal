<%- layout('/layouts/boilerplate.ejs') %>
<% block('head').append('<link rel="stylesheet" href="/stylesheets/static-page.css">') %>

<div class="static-page-container">
    <div class="static-hero">
        <h1><i class="bi bi-bank"></i> Government Schemes</h1>
        <p>Explore Rajasthan government schemes for employment, skill development, and welfare.</p>
    </div>

    <div class="static-content">
        <div class="info-cards">
            <div class="info-card">
                <i class="bi bi-tools"></i>
                <h3>Rajasthan Kaushal &amp; Livelihood</h3>
                <p>Skill training programs for youth under RKCL and allied bodies across all districts.</p>
                <a href="https://rkcl.vmou.ac.in/" target="_blank" class="card-link">Learn More <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="info-card">
                <i class="bi bi-cash-coin"></i>
                <h3>Mukhyamantri Yuva Sambal Yojana</h3>
                <p>Unemployment allowance for educated youth while they search for employment.</p>
                <a href="https://employment.livelihoods.rajasthan.gov.in/" target="_blank" class="card-link">Learn More <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="info-card">
                <i class="bi bi-person-workspace"></i>
                <h3>Indira Gandhi Shahri Rojgar</h3>
                <p>100-day employment guarantee scheme for urban families in Rajasthan.</p>
                <a href="https://schemes.rajasthan.gov.in/" target="_blank" class="card-link">Learn More <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="info-card">
                <i class="bi bi-shop"></i>
                <h3>Rajasthan MSME Scheme</h3>
                <p>Support for micro, small, and medium enterprises including loans and subsidies.</p>
                <a href="https://rajmsme.gov.in/" target="_blank" class="card-link">Learn More <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="info-card">
                <i class="bi bi-stars"></i>
                <h3>All Rajasthan Schemes</h3>
                <p>Browse the complete list of state government welfare and employment schemes.</p>
                <a href="https://schemes.rajasthan.gov.in/?lan=en" target="_blank" class="card-link">View All Schemes <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>
